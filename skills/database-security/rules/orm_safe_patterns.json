{
  "schema_version": "1.0",
  "last_updated": "2026-05-13",
  "description": "Per-ORM safe patterns plus the unsafe escape hatches to avoid.",
  "orms": [
    {
      "name": "Django ORM",
      "safe": ["Model.objects.filter(name=name)", "Model.objects.raw('SELECT * FROM t WHERE id=%s', [id])"],
      "unsafe": ["Model.objects.raw(f'SELECT * FROM t WHERE id={id}')", "extra(where=[f\"name='{name}'\"])"],
      "cwe": 89
    },
    {
      "name": "SQLAlchemy",
      "safe": ["session.execute(text('SELECT * FROM t WHERE id=:id'), {'id': id})", "session.query(M).filter(M.id == id)"],
      "unsafe": ["session.execute(f\"SELECT * FROM t WHERE id={id}\")", "session.query(M).filter(text(f'name = \\'{name}\\''))"],
      "cwe": 89
    },
    {
      "name": "Sequelize",
      "safe": ["Model.findAll({ where: { name } })", "sequelize.query('SELECT * FROM t WHERE id=:id', { replacements: { id }, type: QueryTypes.SELECT })"],
      "unsafe": ["sequelize.query(`SELECT * FROM t WHERE id=${id}`)"],
      "cwe": 89
    },
    {
      "name": "Prisma",
      "safe": ["prisma.user.findUnique({ where: { id } })", "prisma.$queryRaw`SELECT * FROM \"User\" WHERE id = ${id}`"],
      "unsafe": ["prisma.$queryRawUnsafe(`SELECT * FROM \"User\" WHERE id = ${id}`)"],
      "cwe": 89
    },
    {
      "name": "TypeORM",
      "safe": [".createQueryBuilder().where('id = :id', { id })"],
      "unsafe": [".createQueryBuilder().where(`id = ${id}`)"],
      "cwe": 89
    },
    {
      "name": "Go database/sql",
      "safe": ["db.QueryContext(ctx, 'SELECT * FROM t WHERE id = $1', id)"],
      "unsafe": ["db.Query(fmt.Sprintf(\"SELECT * FROM t WHERE id=%d\", id))"],
      "cwe": 89
    },
    {
      "name": "GORM",
      "safe": ["db.Where(\"id = ?\", id).First(&u)"],
      "unsafe": ["db.Where(fmt.Sprintf(\"id = %d\", id)).First(&u)"],
      "cwe": 89
    },
    {
      "name": "ActiveRecord",
      "safe": ["User.where('id = ?', id)", "User.where(id: id)"],
      "unsafe": ["User.where(\"id = #{id}\")", "User.find_by_sql(\"SELECT * FROM users WHERE id=#{id}\")"],
      "cwe": 89
    },
    {
      "name": "Spring Data JPA",
      "safe": ["@Query(\"select u from User u where u.email = :email\")\nUser find(@Param(\"email\") String email);"],
      "unsafe": ["entityManager.createQuery(\"select u from User u where u.email = '\" + email + \"'\")"],
      "cwe": 89
    },
    {
      "name": "Dapper",
      "safe": ["conn.Query<User>(\"select * from Users where Id = @Id\", new { Id = id })"],
      "unsafe": ["conn.Query<User>($\"select * from Users where Id = {id}\")"],
      "cwe": 89
    }
  ]
}
