    {
      "name": "AWS Access Key",
      "regex": "AKIA[0-9A-Z]{16}",
      "prefix": "AKIA",
      "severity": "critical",
      "score_weight": 1,
      "denylist_substrings": [
        "EXAMPLE",
        "AKIAIOSFODNN7"
      ],
      "hotwords": [
        "aws",
        "access_key",
        "credentials",
        "iam",
        "secret"
      ],
      "hotword_window": 200,
      "hotword_boost": 2,
      "require_hotword": false,
      "entropy_min": 3.5
    },
    {
