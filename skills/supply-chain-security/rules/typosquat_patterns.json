{
  "schema_version": "1.0",
  "last_updated": "2026-05-13",
  "description": "Heuristics and corpora for detecting typosquats. The CLI computes Levenshtein distance against the top-1000 list per ecosystem, applies character substitution and homoglyph checks, and consults the known_typosquats corpus for fast hits.",
  "rules": [
    {
      "id": "levenshtein-2",
      "description": "Reject candidate packages within Levenshtein distance 2 of a top-1000 package",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "threshold": 2,
      "exempt_authors": []
    },
    {
      "id": "levenshtein-1-strict",
      "description": "Single edit away from a top-100 package is almost always a typosquat; treat as critical",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "threshold": 1,
      "severity": "critical"
    },
    {
      "id": "char-swap",
      "description": "Detect adjacent-character transposition (axios -> axois, lodash -> lodahs)",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "threshold": 1
    },
    {
      "id": "char-substitution",
      "description": "Detect single-character substitutions across commonly-confused pairs",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "substitutions": [
        ["l", "1"],
        ["l", "i"],
        ["i", "l"],
        ["i", "1"],
        ["o", "0"],
        ["0", "o"],
        ["m", "n"],
        ["n", "m"],
        ["s", "z"],
        ["z", "s"],
        ["u", "v"],
        ["v", "u"]
      ]
    },
    {
      "id": "homoglyph",
      "description": "Detect Unicode-confusable homoglyph substitutions (rеact with Cyrillic 'е' instead of Latin 'e')",
      "ecosystems": ["npm", "pypi"],
      "confusables": [
        ["e", "е"],
        ["a", "а"],
        ["o", "о"],
        ["c", "с"],
        ["p", "р"],
        ["x", "х"],
        ["y", "у"],
        ["i", "і"]
      ]
    },
    {
      "id": "suffix-impersonation",
      "description": "Detect packages mimicking another with a generic suffix appended",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "suspicious_suffixes": ["-js", "-lib", "-core", "-utils", "-tools", "-helper", "-fork", "-node", "-async", "-sync", "-cli", "-sdk"]
    },
    {
      "id": "prefix-impersonation",
      "description": "Detect packages mimicking another with a generic prefix prepended",
      "ecosystems": ["npm", "pypi", "crates", "go"],
      "suspicious_prefixes": ["node-", "py-", "lib-", "go-", "rs-", "real-", "true-", "official-"]
    },
    {
      "id": "scope-strip",
      "description": "Detect unscoped versions of widely-used scoped packages (@types/react vs types-react)",
      "ecosystems": ["npm"],
      "examples": [
        {"scoped": "@types/react", "squat": "types-react"},
        {"scoped": "@babel/core", "squat": "babel-core-pkg"},
        {"scoped": "@angular/core", "squat": "angular-core"}
      ]
    },
    {
      "id": "punycode-domain",
      "description": "Detect names that decode through punycode to popular names",
      "ecosystems": ["npm", "pypi"],
      "match": "starts_with:xn--"
    }
  ],
